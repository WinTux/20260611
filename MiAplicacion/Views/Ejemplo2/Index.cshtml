<div class="card shadow-sm mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Resultados</h4>
    </div>

    <div class="card-body">
        <ul class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>Resultado 1</span>
                <span class="fw-bold text-primary">@ViewBag.resultado1</span>
            </li>

            <li class="list-group-item d-flex justify-content-between">
                <span>Resultado 2</span>
                <span class="fw-bold text-primary">@ViewBag.resultado2</span>
            </li>

            <li class="list-group-item d-flex justify-content-between">
                <span>Resultado 3</span>
                <span class="fw-bold text-primary">@ViewBag.resultado3</span>
            </li>

            <li class="list-group-item d-flex justify-content-between">
                <span>Resultado 4</span>
                <span class="fw-bold text-primary">@ViewBag.resultado4</span>
            </li>

            <li class="list-group-item d-flex justify-content-between">
                <span>Resultado 5</span>
                <span class="fw-bold text-primary">@ViewBag.resultado5</span>
            </li>
        </ul>
    </div>
</div>