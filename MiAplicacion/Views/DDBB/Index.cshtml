<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Lista de productos</h3>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-center">Foto</th>
                            <th class="text-center">Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in ViewBag.productos)
                        {
                            <tr>
                                <td>@p.Id</td>
                                <td>@p.Nombre</td>
                                <td class="text-end">Bs. @p.Precio</td>
                                <td class="text-center">@p.Cantidad</td>
                                <td class="text-center">
                                    <img src="~/imagenes/@p.Foto"
                                         alt="@p.Nombre"
                                         class="img-thumbnail"
                                         style="width:80px; height:80px; object-fit:cover;">
                                </td>
                                <td class="text-center"> 
                                    <a asp-controller="ddbb" asp-action="Modificar" asp-route-id="@p.Id" class="btn btn-warning btn-sm me-2"> Editar </a> 
                                    <a asp-controller="ddbb" asp-action="Eliminar" asp-route-id="@p.Id" class="btn btn-danger btn-sm" onclick="return confirm('¿Desea eliminar este producto?');"> Eliminar </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <a class="btn btn-info" asp-controller="ddbb" asp-action="Agregar">Registrar nuevo producto</a>
</div>