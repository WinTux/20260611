<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Datos de la cuenta registrada</h3>
                </div>

                <div class="card-body">

                    <table class="table table-striped table-hover align-middle">
                        <tbody>
                            <tr>
                                <th style="width: 30%;">ID</th>
                                <td>@ViewBag.Cuenta.Id</td>
                            </tr>

                            <tr>
                                <th>Nombre de usuario</th>
                                <td>@ViewBag.Cuenta.NombreUsuario</td>
                            </tr>

                            <tr>
                                <th>Password</th>
                                <td>
                                    <span class="text-muted">
                                        @ViewBag.Cuenta.Password
                                    </span>
                                </td>
                            </tr>

                            <tr>
                                <th>Descripción</th>
                                <td>@ViewBag.Cuenta.Descripcion</td>
                            </tr>

                            <tr>
                                <th>Disponible</th>
                                <td>
                                    @if (ViewBag.Cuenta.Disponible)
                                    {
                                        <span class="badge bg-success">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No</span>
                                    }
                                </td>
                            </tr>

                            <tr>
                                <th>Género</th>
                                <td>
                                    @{
                                        string genero = ViewBag.Cuenta.Genero switch
                                        {
                                            "F" => "Femenino",
                                            "M" => "Masculino",
                                            _ => "Otro"
                                        };
                                    }
                                    @genero
                                </td>
                            </tr>

                            <tr>
                                <th>Lenguajes de programación</th>
                                <td>
                                    @foreach (var len in ViewBag.Cuenta.Lenguajes)
                                    {
                                        <span class="badge bg-primary me-1 mb-1">
                                            @len
                                        </span>
                                    }
                                </td>
                            </tr>

                            <tr>
                                <th>Cargo</th>
                                <td>
                                    <span class="badge bg-secondary">
                                        @ViewBag.Cuenta.Cargo
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>

                <div class="card-footer text-end">
                    <a asp-controller="Cuenta"
                       asp-action="Registrar"
                       class="btn btn-outline-primary">
                        Registrar otra cuenta
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>