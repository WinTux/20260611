<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">🛒 Tu carrito</h3>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Id</th>
                            <th>Nombre</th>
                            <th>Foto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th>Sub Total</th>
                            <th>Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Item item in ViewBag.carrito)
                        {
                            <tr>
                                <td>@item.producto.Id</td>
                                <td>@item.producto.Nombre</td>
                                <td>
                                    <img src="~/imagenes/@item.producto.Foto"
                                         class="img-thumbnail"
                                         style="height:100px;width:auto;" />
                                </td>
                                <td>Bs. @item.producto.Precio</td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @item.Cantidad
                                    </span>
                                </td>
                                <td>
                                    <strong>
                                        Bs. @(item.producto.Precio * item.Cantidad)
                                    </strong>
                                </td>
                                <td>
                                    <a asp-controller="Carrito"
                                       asp-action="Eliminar"
                                       asp-route-id="@item.producto.Id"
                                       class="btn btn-danger btn-sm">
                                        🗑 Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr class="table-primary">
                            <td colspan="5" class="text-end fw-bold">
                                Total:
                            </td>
                            <td colspan="2" class="fw-bold fs-5">
                                Bs. @ViewBag.total
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a asp-controller="Sesiones"
                   asp-action="EjemploCarrito"
                   class="btn btn-outline-primary">
                    ← Seguir comprando
                </a>

                <button class="btn btn-success">
                    Finalizar compra
                </button>
            </div>
        </div>
    </div>
</div>