<h3>Pagina de login</h3>
@ViewBag.error
<form method="post" asp-controller="Login" asp-action="Login">
    <table>
        <tr>
            <td>Usuario:</td>
            <td><input type="text" name="usuario" /></td>
        </tr>
        <tr>
            <td>Contraseña:</td>
            <td><input type="password" name="password" /></td>
        </tr>
        <tr>
            <td></td>
            <td><input type="submit" value="Login"/></td>
        </tr>
    </table>
</form>